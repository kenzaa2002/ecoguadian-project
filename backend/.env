# ── EcoGuardian Backend – Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=EcoGuardian
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecoguardian:ecoguardian@localhost:5432/ecoguardian

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=1874c04310ec25fbc98014f11cb5560944c5aea8a7608d5186f2234d6ee2295f
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── CORS (comma-separated) ────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── ML Model paths (relative to backend/) ────────────────────────────────────
MODEL_PATH=app/ml/models/smart_home_model.pkl
FEATURES_PATH=app/ml/models/smart_home_features.pkl

# ── Energy pricing ────────────────────────────────────────────────────────────
ENERGY_PRICE_TND=0.199

# ── Anthropic (optional – chatbot falls back to rules if not set) ─────────────
ANTHROPIC_API_KEY=
